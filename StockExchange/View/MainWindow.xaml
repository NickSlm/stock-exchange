<Window x:Class="StockExchange.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockExchange"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid ItemsSource="{Binding Pairs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Base"
                                    Binding="{Binding BaseCurrency.Abbreviation}" />
                <DataGridTextColumn Header="Quote"
                                    Binding="{Binding QuoteCurrency.Abbreviation}" />
                <DataGridTextColumn Header="Current"
                                    Binding="{Binding CurrentValue, StringFormat={}{0:F4}}"  />
                <DataGridTextColumn Header="Min"
                                    Binding="{Binding MinValue, StringFormat={}{0:F4}}" />
                <DataGridTextColumn Header="Max"
                                    Binding="{Binding MaxValue, StringFormat={}{0:F4}}" />
            </DataGrid.Columns>
            
        </DataGrid>
    </Grid>
</Window>
